# Copy this file to .env for local development. Never commit .env.
# In AKS, these values come from Azure Key Vault via the CSI Secret Store Driver.

# Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-placeholder

# Comma-separated list of origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# Note: embeddings use a local sentence-transformers model, so no
# embedding API key is required. The model is downloaded once on
# first run and cached under ~/.cache/huggingface/.
