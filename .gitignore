# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/

# Node / React
node_modules/
frontend/build/
frontend/dist/
.next/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!terraform.tfvars.example
.terraform.lock.hcl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Secrets (never commit these)
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# Splunk
splunk/var/

# FAISS local persistence
*.faiss
*.pkl

# Claude Code
.claude/settings.json

# Knowledge base PDFs (copyrighted material, load at runtime or via volume mount)
app/knowledge_base/pdfs/*.pdf

# Terraform-generated SSH private key for the Splunk VM.
# Folder is tracked via .gitkeep; the actual splunk.pem is never committed.
infra/private_key/*
!infra/private_key/.gitkeep

# Terraform local plan file from tf-plan.sh wrapper
infra/terraform/tfplan

# Bootstrap module uses local state — keep it out of git
infra/terraform-bootstrap/terraform.tfstate
infra/terraform-bootstrap/terraform.tfstate.backup
infra/terraform-bootstrap/.terraform/
infra/terraform-bootstrap/.terraform.lock.hcl
